# Minimum to run: an API key for the parse route. Server-side only.
# Set these in Vercel project settings too.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional: route through a LiteLLM (OpenAI-compatible) gateway instead of api.anthropic.com.
# LITELLM_API_KEY falls back to ANTHROPIC_API_KEY if unset.
# LITELLM_BASE_URL=https://litellm.example.com/v1
# LITELLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# LITELLM_MODEL=claude-haiku-4-5-20251001
